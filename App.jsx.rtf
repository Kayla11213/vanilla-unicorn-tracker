            <option value="Manager">Manager (20%)</option>\
          </select>\
        </div>\
\
        \{/* VIP */\}\
        <div className="text-center mb-4">\
          <button\
            onClick=\{() => setVipDiscount(!vipDiscount)\}\
            className=\{`px-4 py-2 rounded-xl border $\{\
