  return (\
    <div className="min-h-screen bg-black text-pink-400 p-4">\
      <div className="max-w-4xl mx-auto">\
        <h1 className="text-3xl font-bold text-center text-pink-500 mb-4">\
          \uc0\u55358 \u56708  Vanilla Unicorn Tracker \u55358 \u56708 \
