        \{/* Sections */\}\
        \{renderSection("Singles", singles)\}\
        \{renderSection("3x3 & Small Bundles", bundles3)\}\
        \{renderSection("12x12 & Large Bundles", bundles12)\}\
\
        \{/* Totals */\}\
        <div className="text-center mb-4">\
          <p>Total: $\{total\}</p>\
          <p className="text-green-400">\
