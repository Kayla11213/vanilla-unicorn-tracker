\f0\fs24 \cf0 import React, \{ useState, useEffect \} from "react";\
\
export default function CommissionSite() \{\
  const [rank, setRank] = useState("Bartender");\
  const [name, setName] = useState("");\
  const [savedNames, setSavedNames] = useState([]);\
  const [weeklyData, setWeeklyData] = useState(\{\});\
  const [cart, setCart] = useState(\{\});\
  const [vipDiscount, setVipDiscount] = useState(false);\
\
  const commissions = \{\
    Bartender: 0.15,\
    Manager: 0.2,\
  \};\
\
  const singles = [\
    ["Sliders", 300],\
    ["Basic Drink", 250],\
    ["Mixed Drink", 350],\
  ];\
\
  const bundles3 = [\
    ["3 Basic", 600],\
    ["3 Mixed", 900],\
    ["3x3 Basic", 1200],\
    ["3x3 Mixed", 1500],\
  ];\
\
  const bundles12 = [\
    ["12 Basic", 2500],\
    ["12 Mixed", 3500],\
    ["12x12 Basic", 4500],\
    ["12x12 Mixed", 6000],\
  ];\
\
  useEffect(() => \{\
    const saved = localStorage.getItem("vu_commissions");\
    const names = localStorage.getItem("vu_names");\
    if (saved) setWeeklyData(JSON.parse(saved));\
    if (names) setSavedNames(JSON.parse(names));\
  \}, []);\
\
  useEffect(() => \{\
    localStorage.setItem("vu_commissions", JSON.stringify(weeklyData));\
  \}, [weeklyData]);\
\
