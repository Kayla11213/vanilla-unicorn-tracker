\
    const newData = \{\
      ...weeklyData,\
      [name]: \{\
        sales: prev.sales + total,\
        commission: prev.commission + commissionEarned,\
      \},\
    \};\
\
    setWeeklyData(newData);\
\
    // DISCORD WEBHOOK\
    try \{\
      await fetch("https://discord.com/api/webhooks/1485149118832578563/NUMjDIthuaR1TUT57ZleD-fGmKzxd87vocAjUZACulP7cIeKVUCWEKOFMi1ii9WaQBD2", \{\
        method: "POST",\
        headers: \{ "Content-Type": "application/json" \},\
        body: JSON.stringify(\{\
          content: `\uc0\u55357 \u56470  Sale Logged \u55357 \u56470 \\n$\{name\} ($\{rank\})\\nSale: $$\{total\}\\nCommission: $$\{commissionEarned.toFixed(2)\}`,\
        \}),\
      \});\
